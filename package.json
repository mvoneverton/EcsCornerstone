{
  "name": "ecscornerstone",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspace=packages/api",
    "db:migrate": "npm run db:migrate --workspace=packages/api",
    "start": "npm run db:migrate && node packages/api/dist/index.js",
    "build:marketing": "npm install --workspace=packages/marketing && npm run build --workspace=packages/marketing",
    "start:marketing": "node packages/marketing/serve.js"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
