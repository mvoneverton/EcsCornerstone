# ── ECS Cornerstone — Staging Environment Variables ──────────────────────────
# Copy this file, fill in every value, then paste into Railway → Service → Variables.
# Lines marked [Railway] are injected automatically by the corresponding plugin.

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=           # [Railway] provided by the PostgreSQL plugin

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=              # [Railway] provided by the Redis plugin

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=      # generate a strong random string (min 32 chars)
JWT_REFRESH_SECRET=     # generate a DIFFERENT strong random string (min 32 chars)
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d

# ── SendGrid (invitation & report emails) ─────────────────────────────────────
SENDGRID_API_KEY=       # SG.xxxx — from sendgrid.com → Settings → API Keys
SENDGRID_FROM_EMAIL=noreply@evertoncs.com
SENDGRID_FROM_NAME=ECS Cornerstone

# ── AWS S3 (PDF report storage) ───────────────────────────────────────────────
AWS_ACCESS_KEY_ID=      # IAM user with s3:PutObject / s3:GetObject on the bucket
AWS_SECRET_ACCESS_KEY=  #
AWS_REGION=us-east-1
AWS_S3_BUCKET=          # e.g. ecscornerstone-reports-staging

# ── Stripe ────────────────────────────────────────────────────────────────────
# Use TEST keys for staging — they start with sk_test_ / whsec_
STRIPE_SECRET_KEY=      # sk_test_… from Stripe dashboard → Developers → API keys
STRIPE_WEBHOOK_SECRET=  # whsec_… from Stripe dashboard → Developers → Webhooks
                        # Webhook endpoint URL: https://<railway-url>/api/billing/webhook
STRIPE_PRICE_STARTER_MONTHLY=price_
STRIPE_PRICE_STARTER_ANNUALLY=price_
STRIPE_PRICE_GROWTH_MONTHLY=price_
STRIPE_PRICE_GROWTH_ANNUALLY=price_

# ── Application ───────────────────────────────────────────────────────────────
PORT=3001               # [Railway] overrides this automatically — leave as-is
NODE_ENV=production
FRONTEND_URL=           # the Railway public URL once deployed, e.g. https://ecscornerstone-staging.up.railway.app
                        # also set this as CORS_ORIGIN if you later split API/frontend
CORS_ORIGIN=            # same as FRONTEND_URL (single unified service — same origin)
APP_URL=                # same as FRONTEND_URL

# ── Puppeteer (PDF generation) ────────────────────────────────────────────────
# Railway's Nixpacks environment bundles Chromium — skip the redundant download.
PUPPETEER_SKIP_DOWNLOAD=true
PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium-browser
