# ── ECS Cornerstone Web — Environment Variables ───────────────────────────────
# These are build-time variables baked into the Vite bundle (prefix: VITE_).
# In production the API serves the frontend, so the API base URL is the same
# origin — no separate variable needed.  These are only required for local dev
# overrides or if you deploy the frontend independently.

# API base URL for local dev (Vite proxy handles this automatically in dev mode)
VITE_API_BASE_URL=http://localhost:3001
