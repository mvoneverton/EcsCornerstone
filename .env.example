# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://ecscornerstone:devpassword@localhost:5432/ecscornerstone

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT ───────────────────────────────────────────────────────────────────────
# Secrets must be at least 32 characters in production — use a random generator
JWT_ACCESS_SECRET=replace-with-random-secret-min-32-characters
JWT_REFRESH_SECRET=replace-with-different-random-secret-min-32-chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d

# ── SendGrid ──────────────────────────────────────────────────────────────────
SENDGRID_API_KEY=SG.replace-with-your-api-key
SENDGRID_FROM_EMAIL=noreply@evertoncs.com
SENDGRID_FROM_NAME=ECS Cornerstone

# ── AWS S3 ────────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=replace-with-your-access-key
AWS_SECRET_ACCESS_KEY=replace-with-your-secret-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=ecscornerstone-reports

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_replace-with-your-key
STRIPE_WEBHOOK_SECRET=whsec_replace-with-your-webhook-secret
STRIPE_PRICE_STARTER_MONTHLY=price_replace
STRIPE_PRICE_STARTER_ANNUALLY=price_replace
STRIPE_PRICE_GROWTH_MONTHLY=price_replace
STRIPE_PRICE_GROWTH_ANNUALLY=price_replace

# ── App ───────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173
APP_URL=http://localhost:5173
# In production/staging this is the public Railway URL (same as CORS_ORIGIN/APP_URL)
FRONTEND_URL=http://localhost:5173

# ── Puppeteer ─────────────────────────────────────────────────────────────────
# Set to 'true' in production Docker environments if Chromium is bundled
PUPPETEER_SKIP_DOWNLOAD=false
